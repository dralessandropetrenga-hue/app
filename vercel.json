{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "functions": {
    "api/analyze.js": { "maxDuration": 60 },
    "api/transcribe.js": { "maxDuration": 60 },
    "api/ghl.js": { "maxDuration": 60 }
  },
  "routes": [
    {
      "src": "/api/transcribe",
      "dest": "/api/transcribe.js"
    },
    {
      "src": "/api/analyze",
      "dest": "/api/analyze.js"
    },
    {
      "src": "/api/ghl",
      "dest": "/api/ghl.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
